{
  "name": "twitter-clone",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:web dev:server",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
