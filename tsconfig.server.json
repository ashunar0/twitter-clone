{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "outDir": "./dist/server",
    "baseUrl": ".",
    "paths": {
      "@server/*": ["server/*"],
      "@features/*": ["features/*"]
    },
    "types": ["node"]
  },
  "include": ["server", "features"]
}
